# 이 파일을 복사해서 .env 로 만들고 값을 채우세요 (cp .env.example .env)
# .env 는 절대 git에 올리지 마세요 (.gitignore로 제외됨)

# Supabase 프로젝트 설정 → Project Settings → Data API / API Keys 에서 확인
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service_role 키 (secret). 서버에서만 사용, 외부 노출 금지
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# 수집할 치지직 채널 ID (방송 URL의 /live/ 뒤 문자열)
CHANNEL_ID=508279ea46820b3104c9c9944bebf07e
